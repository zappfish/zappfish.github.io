---
interface Props {
    title: string
    image?: string
    imageLeft?: string
    imageRight?: string
}
const { title, image, imageLeft, imageRight } = Astro.props
---
<div class:list={['hero', { 'hero--image': !!image, 'hero--fish': !!imageLeft || !!imageRight }]}>
    {imageLeft  && <img src={imageLeft}  alt="" aria-hidden="true" class="hero-fish hero-fish--left" />}
    {imageRight && <img src={imageRight} alt="" aria-hidden="true" class="hero-fish hero-fish--right" />}
    <div class="hero-inner">
        <h1>{title}</h1>
        <slot />
    </div>
    {image && <img src={image} alt="" aria-hidden="true" class="hero-photo" />}
</div>

<style>
    .hero {
        background: #dde4eb;
        padding: var(--space-12) var(--space-8);
        min-height: 160px;
        max-height: 330px;
        text-align: center;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
    }

    /* Hero with gradient background and side-by-side text + photo */
    .hero--image {
        background: linear-gradient(to right, #1d3a4a 0%, #245869 30%, #2e6879 60%, #7ab0be 100%);
        justify-content: center;
        gap: var(--space-10);
        min-height: 290px;
        padding: var(--space-8) var(--space-12);
    }

    .hero--image h1 {
        color: #fff;
        font-size: clamp(2rem, 4vw, 3rem);
        letter-spacing: -0.01em;
        margin-bottom: var(--space-2);
    }

    .hero-photo {
        flex-shrink: 0;
        width: 340px;
        height: 300px;
        object-fit: cover;
        border-radius: 16px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.25);
        border: 3px solid rgba(255,255,255,0.2);
        z-index: 1;
    }

    /* Fish images — both on the right */
    .hero-fish {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        height: 85%;
        width: auto;
        max-width: 22%;
        object-fit: contain;
        z-index: 0;
        mix-blend-mode: multiply;
    }

    .hero-fish--left  { right: 26%; }
    .hero-fish--right { right: 3%; transform: translateY(-50%) scaleX(-1); }

    /* Fish layout — blue-gray overlay with edge vignette */
    .hero--fish {
        background:
            linear-gradient(to right, rgba(70, 90, 110, 0.50) 0%, transparent 40%, transparent 60%, rgba(70, 90, 110, 0.50) 100%),
            linear-gradient(to bottom, rgba(70, 90, 110, 0.35), transparent 30%, transparent 70%, rgba(70, 90, 110, 0.25)),
            rgb(195, 205, 215);
    }

    .hero--fish h1 {
        color: var(--color-text-white);
        font-size: var(--font-size-display);
        margin-bottom: var(--space-3);
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 960px;
        margin: 0 auto;
        width: 100%;
    }

    .hero--image .hero-inner {
        max-width: 50%;
        margin: 0;
        text-align: left;
    }

    h1 { color: var(--color-primary); font-weight: var(--font-weight-bold); margin-bottom: var(--space-8); }

    @media (max-width: 1250px) {
        .hero-photo { display: none; }
        .hero--image .hero-inner {
            max-width: 960px;
            margin: 0 auto;
            text-align: center;
        }
    }

    @media (max-width: 768px) {
        .hero { padding: var(--space-12) var(--space-6); }
        .hero-fish { display: none; }
    }
</style>
