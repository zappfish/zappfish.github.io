---
const { title } = Astro.props;
---
<div class="hero">
    <h1>{title}</h1>
</div>

<style>
    .hero { background: var(--color-primary); padding: var(--space-12) var(--space-8); text-align: center; }

    h1 { color: var(--color-text-white); font-weight: var(--font-weight-bold); margin: 0; }
</style>
