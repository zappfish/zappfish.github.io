---
interface Props {
    title: string
    image?: string
}
const { title, image } = Astro.props
---
<div class:list={['hero', { 'hero--image': !!image }]} style={image ? `background-image: url('${image}')` : undefined}>
    <div class="hero-inner">
        <h1>{title}</h1>
        <slot />
    </div>
</div>

<style>
    .hero {
        background: var(--color-bg-white);
        padding: var(--space-16) var(--space-8);
        text-align: center;
        position: relative;
    }

    .hero--image {
        background-size: auto 100%;
        background-position: right -5% center;
        background-repeat: no-repeat;
    }

    .hero--image::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            linear-gradient(to right,  rgba(70, 90, 110, 0.78) 0%, rgba(70, 90, 110, 0.78) 25%, rgba(70, 90, 110, 0.05) 75%, transparent 100%),
            linear-gradient(to bottom, rgba(70, 90, 110, 0.35), transparent 30%, transparent 70%, rgba(70, 90, 110, 0.25));
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 960px;
        margin: 0 auto;
    }

    h1 { color: var(--color-primary); font-weight: var(--font-weight-bold); margin-bottom: var(--space-8); }
    .hero--image h1 { color: var(--color-text-white); }

    @media (max-width: 768px) {
        .hero { padding: var(--space-12) var(--space-6); }
        .hero--image {
            background-size: auto 50%;
            background-position: right center;
        }
    }
</style>
