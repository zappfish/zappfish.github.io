---
import { navItems } from "../config/nav"
const quickLinks = navItems
---

<footer class="site-footer">
    <div class="footer-inner">

        <div class="footer-brand">
            <p>Zebrafish Toxicology Phenotype Atlas Project</p>
            <a href="mailto:info@zappfish.org">info@zappfish.org</a>
        </div>

        <nav class="footer-links" aria-label="Footer navigation">
            <h4 class="footer-heading">Quick Links</h4>
            <ul class="footer-link-list">
                {quickLinks.map(({ label, path }) => <li><a href={path}>{label}</a></li>)}
            </ul>
        </nav>

    </div>
    <div class="footer-bottom">
        <p>The ZAPP project is supported by NIEHS 1R24ES036130<br />Advancing a community-led zebrafish toxicology phenotype atlas.</p>
    </div>
</footer>

<style>
    .site-footer { background-color: var(--color-bg-card); color: var(--color-text-dark); width: 100%; }

    .footer-inner {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: var(--space-12);
        max-width: 1280px;
        margin: 0 auto;
        padding: var(--space-12) var(--space-8);
        box-sizing: border-box;
    }

    /* Shared muted text on light background */
    .footer-brand p,
    .footer-brand a,
    .footer-link-list li a,
    .footer-contact p,
    .footer-contact a {
        color: var(--color-text-muted);
        text-decoration: none;
        line-height: var(--line-height-base);
        margin-bottom: var(--space-1);
    }

    /* Single hover rule covers all footer links */
    .footer-brand a:hover,
    .footer-link-list li a:hover { color: var(--color-primary); }

    .footer-heading { color: var(--color-primary-dark); font-weight: var(--font-weight-bold); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-4); }

    .footer-link-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }


    .footer-bottom { border-top: 1px solid var(--color-border); text-align: center; padding: var(--space-4) var(--space-8); }

    .footer-bottom p { color: var(--color-text-muted); margin: 0; line-height: var(--line-height-base); font-size: var(--font-size-sm); }

    /* Stack columns on mobile, center-align content */
    @media (max-width: 768px) {
        .footer-inner { grid-template-columns: 1fr; gap: var(--space-8); text-align: center; }
    }
</style>
