---
import { getCollection, render } from "astro:content"
import Main from '../layouts/Main.astro'
import Hero from '../layouts/Hero.astro'

const eventsUnsorted = await getCollection("events")

const today = new Date()
today.setHours(0, 0, 0, 0)

const events = eventsUnsorted.sort((a, b) =>
    new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
)

const upcoming = events.filter(e => new Date(e.data.date) >= today)
const past     = [...events].filter(e => new Date(e.data.date) < today).reverse()
---

<Main title="Events">

    <Hero title="Events" variant="teal" slot="hero" />

    <section class="intro">
        <div class="section-label">Workshops &amp; Meetings</div>
    </section>

    <section class="events">
        <div class="tab-bar" role="tablist">
            <button class="tab-btn active" role="tab" aria-selected="true"  data-tab="past">Past Events</button>
            <button class="tab-btn"        role="tab" aria-selected="false" data-tab="upcoming">Upcoming Events</button>
        </div>

        <div class="tab-panel hidden" id="tab-upcoming">
            {upcoming.length === 0
                ? <p class="empty">No upcoming events at this time. Check back soon!</p>
                : await Promise.all(upcoming.map(async entry => {
                    const { Content } = await render(entry)
                    return (
                        <article class="event-card">
                            <div class="event-header">
                                <span class="event-badge upcoming">Upcoming</span>
                                <span class="event-date">{entry.data.date}</span>
                            </div>
                            <h2 class="event-title">{entry.data.title}</h2>
                            <div class="event-topic">
                                <span class="topic-tag">{entry.data.topic}</span>
                            </div>
                            <div class="event-meta-row">
                                <span class="meta-item">{entry.data.time}</span>
                                <span class="meta-divider" aria-hidden="true" />
                                <span class="meta-item">{entry.data.location}</span>
                            </div>
                            {entry.data.signup && entry.data.signup !== 'Closed' &&
                                <a class="signup-btn" href={entry.data.signup}>Sign Up</a>
                            }
                            <div class="event-content"><Content /></div>
                        </article>
                    )
                }))
            }
        </div>

        <div class="tab-panel" id="tab-past">
            {past.length === 0
                ? <p class="empty">No past events.</p>
                : await Promise.all(past.map(async entry => {
                    const { Content } = await render(entry)
                    return (
                        <article class="event-card past">
                            <div class="event-header">
                                <span class="event-badge past-badge">Past</span>
                                <span class="event-date">{entry.data.date}</span>
                            </div>
                            <h2 class="event-title">{entry.data.title}</h2>
                            <div class="event-topic">
                                <span class="topic-tag">{entry.data.topic}</span>
                            </div>
                            <div class="event-content"><Content /></div>
                        </article>
                    )
                }))
            }
        </div>
    </section>


</Main>

<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
    const panels  = document.querySelectorAll<HTMLElement>('.tab-panel')

    function switchTab(target: string) {
        buttons.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false') })
        panels.forEach(p  => p.classList.add('hidden'))
        const btn = document.querySelector<HTMLButtonElement>(`.tab-btn[data-tab="${target}"]`)
        btn?.classList.add('active')
        btn?.setAttribute('aria-selected', 'true')
        document.getElementById(`tab-${target}`)?.classList.remove('hidden')
    }

    buttons.forEach(btn => {
        btn.addEventListener('click', () => switchTab(btn.dataset.tab!))
    })

</script>

<style>
    .hero-subtitle {
        color: var(--color-text-white);
        opacity: 0.92;
        margin: 0;
        font-size: var(--font-size-body);
    }

    /* ── Tabs ── */
    .tab-bar {
        display: flex;
        gap: var(--space-3);
        margin-bottom: var(--space-8);
    }

    .tab-btn {
        padding: var(--space-2) var(--space-6);
        font: inherit;
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-muted);
        background: none;
        border: 1.5px solid var(--color-border);
        border-radius: 999px;
        cursor: pointer;
        transition: color 0.15s, background 0.15s, border-color 0.15s;
    }

    .tab-btn:hover { color: var(--color-accent); border-color: var(--color-accent); }

    .tab-btn.active {
        background: var(--color-accent);
        color: var(--color-text-white);
        border-color: var(--color-accent);
    }

    .tab-panel.hidden { display: none; }

    /* ── Event card ── */
    .event-card {
        background: var(--color-bg-white);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: var(--space-6) var(--space-8);
        margin-bottom: var(--space-6);
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .event-card.past { background: var(--color-bg-surface); }

    .event-header {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-4);
    }

    .event-badge {
        display: inline-block;
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 2px var(--space-3);
        border-radius: 4px;
    }

    .event-badge.upcoming {
        background: var(--color-accent);
        color: var(--color-text-white);
    }

    .event-badge.past-badge {
        background: var(--color-bg-light);
        color: var(--color-text-muted);
        border: 1px solid var(--color-border);
    }

    .event-date {
        font-size: var(--font-size-base);
        color: var(--color-text-muted);
        font-weight: var(--font-weight-bold);
    }

    .event-title {
        font-size: var(--font-size-h2);
        color: var(--color-primary);
        margin-bottom: var(--space-3);
    }

    .event-topic {
        margin-bottom: var(--space-4);
    }

    .topic-tag {
        display: inline-block;
        font-size: var(--font-size-base);
        color: var(--color-primary);
        background: var(--color-bg-light);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 2px var(--space-3);
    }

    .event-meta-row {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-5);
    }

    .meta-item {
        font-size: var(--font-size-base);
        color: var(--color-text-muted);
    }

    .meta-divider {
        width: 1px;
        height: 14px;
        background: var(--color-border);
        flex-shrink: 0;
    }

    .signup-btn {
        display: inline-block;
        margin-bottom: var(--space-6);
        padding: var(--space-3) var(--space-6);
        background: var(--color-accent);
        color: var(--color-text-white);
        border-radius: 6px;
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-bold);
        text-decoration: none;
        transition: background 0.15s;
    }

    .signup-btn:hover { background: var(--color-accent-hover); }

    /* ── Rendered markdown content ── */
    .event-content {
        border-top: 1px solid var(--color-border);
        padding-top: var(--space-6);
        margin-top: var(--space-4);
    }

    .event-content :global(strong) {
        color: var(--color-primary);
        font-size: var(--font-size-body);
        display: block;
        margin-top: var(--space-5);
        margin-bottom: var(--space-3);
    }

    .event-content :global(ul) {
        padding-left: var(--list-padding-left);
        margin-bottom: var(--space-4);
    }

    .event-content :global(li) {
        position: relative;
        list-style: none;
        padding-left: var(--space-6);
        margin-bottom: var(--space-2);
    }

    .event-content :global(li::before) {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--color-accent);
        font-weight: var(--font-weight-bold);
    }

    .event-content :global(a) {
        color: var(--color-accent);
        text-decoration: none;
    }

    .event-content :global(a:hover) { text-decoration: underline; }


    .empty {
        color: var(--color-text-muted);
        font-size: var(--font-size-body);
        padding: var(--space-8) 0;
    }
</style>
