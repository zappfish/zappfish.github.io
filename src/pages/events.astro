---
import { getCollection, render } from "astro:content"
import Main from '../layouts/Main.astro'
import Hero from '../layouts/Hero.astro'
import IconCalendar from '../components/icons/IconCalendar.astro'

const eventsUnsorted = await getCollection("events")

const today = new Date()
today.setHours(0, 0, 0, 0)

const events = eventsUnsorted.sort((a, b) =>
    new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
)

const upcoming = events.filter(e => new Date(e.data.date) >= today)
const past     = [...events].filter(e => new Date(e.data.date) < today).reverse()
---

<Main title="Events">

    <Hero title="Events" variant="teal" slot="hero" />

    <section class="intro">
        <div class="section-label">Workshops &amp; Meetings</div>
    </section>

    <section class="events">
        <div class="tab-bar" role="tablist">
            <button class="tab-btn active" role="tab" aria-selected="true"  data-tab="past">Past Events</button>
            <button class="tab-btn"        role="tab" aria-selected="false" data-tab="upcoming">Upcoming Events</button>
        </div>

        <div class="tab-panel hidden" id="tab-upcoming">
            {upcoming.length === 0
                ? <p class="empty">No upcoming events at this time. Check back soon!</p>
                : await Promise.all(upcoming.map(async entry => {
                    const { Content } = await render(entry)
                    return (
                        <article class="event-card">
                            <div class="event-card-header">
                                <span class="event-date"><IconCalendar />{entry.data.date}</span>
                                <h2 class="event-title">{entry.data.title}</h2>
                                <div class="event-topic">
                                    <span class="topic-tag">Topic: {entry.data.topic}</span>
                                </div>
                                <div class="event-meta-row">
                                    <span class="meta-item">{entry.data.time}</span>
                                    <span class="meta-divider" aria-hidden="true" />
                                    <span class="meta-item">{entry.data.location}</span>
                                </div>
                                {entry.data.signup && entry.data.signup !== 'Closed' &&
                                    <a class="signup-btn" href={entry.data.signup}>Sign Up</a>
                                }
                            </div>
                            <div class="event-content"><Content /></div>
                        </article>
                    )
                }))
            }
        </div>

        <div class="tab-panel" id="tab-past">
            {past.length === 0
                ? <p class="empty">No past events.</p>
                : await Promise.all(past.map(async entry => {
                    const { Content } = await render(entry)
                    return (
                        <article class="event-card">
                            <div class="event-card-header">
                                <span class="event-date"><IconCalendar />{entry.data.date}</span>
                                <h2 class="event-title">{entry.data.title}</h2>
                                <div class="event-topic">
                                    <span class="topic-tag">Topic: {entry.data.topic}</span>
                                </div>
                            </div>
                            <div class="event-content"><Content /></div>
                        </article>
                    )
                }))
            }
        </div>
    </section>


</Main>

<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
    const panels  = document.querySelectorAll<HTMLElement>('.tab-panel')

    function switchTab(target: string) {
        buttons.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false') })
        panels.forEach(p  => p.classList.add('hidden'))
        const btn = document.querySelector<HTMLButtonElement>(`.tab-btn[data-tab="${target}"]`)
        btn?.classList.add('active')
        btn?.setAttribute('aria-selected', 'true')
        document.getElementById(`tab-${target}`)?.classList.remove('hidden')
    }

    buttons.forEach(btn => {
        btn.addEventListener('click', () => switchTab(btn.dataset.tab!))
    })

</script>

<style>
    /* ── Tabs ── */
    .tab-bar {
        display: flex;
        gap: var(--space-3);
        margin-bottom: var(--space-8);
    }

    .tab-btn {
        padding: var(--space-2) var(--space-6);
        font: inherit;
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-muted);
        background: none;
        border: 1.5px solid var(--color-border);
        border-radius: 999px;
        cursor: pointer;
        transition: color 0.15s, background 0.15s, border-color 0.15s;
    }

    .tab-btn:hover { color: var(--color-accent); border-color: var(--color-accent); }

    .tab-btn.active {
        background: var(--color-accent);
        color: var(--color-text-white);
        border-color: var(--color-accent);
    }

    .tab-panel.hidden { display: none; }

    /* ── Event card ── */
    .event-card {
        background: var(--color-bg-white);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        margin-bottom: var(--space-6);
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .event-card-header {
        border-left: 4px solid var(--color-accent);
        background: var(--color-bg-surface);
        padding: var(--space-6) var(--space-8) var(--space-6) calc(var(--space-8) - 4px);
    }

    .event-date {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: var(--space-3);
    }

    .event-date :global(svg) {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
    }

    .event-title {
        font-size: var(--font-size-h2);
        color: var(--color-primary);
        margin-bottom: var(--space-3);
    }

    .event-topic {
        margin-bottom: 0;
    }

    .topic-tag {
        display: inline-block;
        font-size: var(--font-size-base);
        color: var(--color-primary);
        background: var(--color-bg-light);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 2px var(--space-3);
    }

    .event-meta-row {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-5);
    }

    .meta-item {
        font-size: var(--font-size-base);
        color: var(--color-text-muted);
    }

    .meta-divider {
        width: 1px;
        height: 14px;
        background: var(--color-border);
        flex-shrink: 0;
    }

    .signup-btn {
        display: inline-block;
        margin-bottom: var(--space-6);
        padding: var(--space-3) var(--space-6);
        background: var(--color-accent);
        color: var(--color-text-white);
        border-radius: 6px;
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-bold);
        text-decoration: none;
        transition: background 0.15s;
    }

    .signup-btn:hover { background: var(--color-accent-hover); }

    /* ── Rendered markdown content ── */
    .event-content {
        border-top: 1px solid var(--color-border);
        padding: var(--space-6) var(--space-8);
    }

    .event-content :global(strong) {
        color: var(--color-primary);
        font-size: var(--font-size-body);
        font-weight: var(--font-weight-bold);
        display: block;
        margin-top: 0;
        margin-bottom: var(--space-4);
    }

    .event-content :global(strong + strong),
    .event-content :global(ul + strong),
    .event-content :global(p + strong) {
        margin-top: var(--space-6);
    }

    .event-content :global(p) {
        margin-bottom: var(--space-3);
    }

    /* Goals list — teal checkmarks */
    .event-content :global(ul:not(:last-of-type)) {
        list-style: none;
        padding-left: 0;
        margin-bottom: var(--space-4);
    }

    .event-content :global(ul:not(:last-of-type) li) {
        position: relative;
        list-style: none;
        padding-left: var(--space-6);
        margin-bottom: var(--space-3);
    }

    .event-content :global(ul:not(:last-of-type) li::before) {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--color-accent);
        font-weight: var(--font-weight-bold);
    }

    /* Resources heading — top of bordered box */
    /* Resources heading — styled icon box */
    .event-content :global(p:has(+ ul:last-of-type)) {
        border: 1px solid var(--color-border);
        border-bottom: none;
        border-radius: 8px 8px 0 0;
        background: var(--color-bg-surface);
        padding: var(--space-4) var(--space-5) var(--space-4);
        margin-top: var(--space-8);
        margin-bottom: -1px !important;
    }

    .event-content :global(p:has(+ ul:last-of-type) > strong) {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin-bottom: 0;
    }

    .event-content :global(p:has(+ ul:last-of-type) > strong::before) {
        content: '📄';
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: var(--color-primary);
        color: white;
        border-radius: 8px;
        font-size: 16px;
        flex-shrink: 0;
    }

    /* Resources list — 2-column card grid */
    .event-content :global(ul:last-of-type) {
        list-style: none;
        padding: var(--space-2) var(--space-5) var(--space-4);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
        margin-top: 0;
        margin-bottom: var(--space-4);
        background: var(--color-bg-surface);
        border: 1px solid var(--color-border);
        border-top: none;
        border-radius: 0 0 8px 8px;
    }

    .event-content :global(ul:last-of-type li) {
        display: grid;
        grid-template-columns: 36px 1fr;
        column-gap: var(--space-3);
        background: var(--color-bg-white);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: var(--space-3) var(--space-4);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-dark);
    }

    .event-content :global(ul:last-of-type li::before) {
        content: '';
        grid-column: 1;
        grid-row: 1 / span 2;
        align-self: center;
        width: 36px;
        height: 36px;
        background-color: var(--color-accent-tint);
        background-repeat: no-repeat;
        background-position: center;
        background-size: 18px 18px;
        border-radius: 8px;
    }

    /* Meeting summary — file-text icon */
    .event-content :global(ul:last-of-type li:nth-child(1)::before) {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%232a9d8a' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/%3E%3Cpolyline points='14 2 14 8 20 8'/%3E%3Cline x1='16' y1='13' x2='8' y2='13'/%3E%3Cline x1='16' y1='17' x2='8' y2='17'/%3E%3Cline x1='10' y1='9' x2='8' y2='9'/%3E%3C/svg%3E");
    }

    /* Recording — video icon */
    .event-content :global(ul:last-of-type li:nth-child(2)::before) {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%232a9d8a' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolygon points='23 7 16 12 23 17 23 7'/%3E%3Crect x='1' y='5' width='15' height='14' rx='2' ry='2'/%3E%3C/svg%3E");
    }

    /* Code of conduct — shield icon */
    .event-content :global(ul:last-of-type li:nth-child(3)::before) {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%232a9d8a' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/%3E%3C/svg%3E");
    }

    /* Slide deck — presentation icon */
    .event-content :global(ul:last-of-type li:nth-child(4)::before) {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%232a9d8a' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='2' y='3' width='20' height='14' rx='2'/%3E%3Cline x1='8' y1='21' x2='16' y2='21'/%3E%3Cline x1='12' y1='17' x2='12' y2='21'/%3E%3C/svg%3E");
    }

    .event-content :global(ul:last-of-type li a),
    .event-content :global(ul:last-of-type li em) {
        display: block;
        font-size: var(--font-size-ui);
        font-weight: normal;
        font-style: normal;
        text-transform: none;
        letter-spacing: 0;
        color: var(--color-text-muted);
        margin-top: var(--space-1);
    }

    .event-content :global(ul:last-of-type li a) {
        color: var(--color-accent);
    }

    .event-content :global(ul:last-of-type li a::after) {
        content: ' →';
    }

    .event-content :global(a) {
        color: var(--color-accent);
        text-decoration: none;
    }

    .event-content :global(a:hover) { text-decoration: underline; }



    .empty {
        color: var(--color-text-muted);
        font-size: var(--font-size-body);
        padding: var(--space-8) 0;
    }
</style>
