---
import Main from '../../layouts/Main.astro'
import Hero from '../../layouts/Hero.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
)
---

<Main title="Blogs">

    <Hero title="Blogs" variant="teal" slot="hero" />

    <section class="intro">
        <div class="section-label">Blogs</div>
        <p class="intro-text">Insights, updates, and perspectives from the ZAPP team. We write about zebrafish research, data standards, ontologies, and the science behind building a community-driven phenotype atlas.</p>
    </section>

    <section class="post-list">
        {posts.map(post => (
            <a class="post-card" href={`/blog/${post.id}`}>
                <div class="post-card-text">
                    <h2 class="post-title">{post.data.title}</h2>
                    <p class="post-excerpt">{post.data.excerpt}</p>
                    <div class="post-footer">
                        <span class="post-date">{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                        <span class="post-read-more">Read more →</span>
                    </div>
                </div>
                {post.data.image && (
                    <div class="post-card-image">
                        <img src={post.data.image} alt={post.data.title} />
                    </div>
                )}
            </a>
        ))}
    </section>

</Main>

<style>
    .intro {
        margin-bottom: var(--space-8);
    }

    .intro-text {
        font-size: var(--font-size-body);
        color: var(--color-text-body);
        line-height: 1.7;
    }

    .post-list {
        display: flex;
        flex-direction: column;
        margin-bottom: var(--space-12);
    }

    .post-card {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-8);
        padding: var(--space-6) 0;
        border-bottom: 1px solid var(--color-border);
        text-decoration: none;
        transition: opacity 0.15s;
    }

    .post-card:first-child { border-top: 1px solid var(--color-border); }
    .post-card:hover { opacity: 0.75; }

    .post-card-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        min-width: 0;
    }

    .post-title {
        font-size: var(--font-size-h3);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-dark);
        margin: 0;
    }

    .post-excerpt {
        font-size: var(--font-size-body);
        color: var(--color-text-body);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .post-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: var(--space-1);
    }

    .post-date {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
    }

    .post-read-more {
        font-size: var(--font-size-action);
        font-weight: var(--font-weight-bold);
        color: var(--color-accent);
    }

    .post-card-image {
        flex-shrink: 0;
        width: 160px;
        height: 107px;
        border-radius: 8px;
        overflow: hidden;
    }

    .post-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (max-width: 600px) {
        .post-card-image { display: none; }
    }
</style>
