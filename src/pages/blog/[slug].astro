---
import Main from '../../layouts/Main.astro'
import LinkedInIcon from '../../icons/linkedin.svg?raw'
import CopyLinkIcon from '../../icons/copy-link.svg?raw'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
    const posts = await getCollection('blog')
    return posts.map(post => ({ params: { slug: post.id.replace(/\.md$/, '') }, props: { post } }))
}

const { post } = Astro.props
const { Content, headings } = await post.render()
---

<Main title={post.data.title}>

    <Fragment slot="hero" />

    <div class="post-layout">

        <header class="post-header">
            <h1 class="post-title">{post.data.title}</h1>
            <div class="post-meta">
                <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span class="post-meta-sep">•</span>
                <span class="post-author">By {post.data.author}</span>
            </div>
        </header>

        <aside class="post-sidebar">
            <a class="back-link" href="/blog">← Back to Blogs</a>

            <div class="sidebar-section">
                <p class="sidebar-section-label">Share Article</p>
                <div class="sidebar-share-item">
                    <a class="sidebar-share-link" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener">
                        <span class="sidebar-share-icon" set:html={LinkedInIcon} aria-hidden="true" />
                        Share on LinkedIn
                    </a>
                </div>
                <div class="sidebar-share-item">
                    <button class="sidebar-share-link sidebar-copy-btn" type="button" data-copy-link>
                        <span class="sidebar-share-icon" set:html={CopyLinkIcon} aria-hidden="true" />
                        <span class="sidebar-copy-label">Copy Link</span>
                    </button>
                </div>
            </div>

            {headings.length > 0 && (
                <div class="sidebar-section">
                    <p class="sidebar-section-label">Table of Contents</p>
                    <nav class="toc">
                        {headings.map(h => (
                            <a class={`toc-link toc-h${h.depth}`} href={`#${h.slug}`}>{h.text}</a>
                        ))}
                    </nav>
                </div>
            )}
        </aside>

        <article class="post-body">
            <div class="post-content">
                <Content />
            </div>
        </article>

    </div>

</Main>

<script>
    document.querySelectorAll('[data-copy-link]').forEach(btn => {
        btn.addEventListener('click', async () => {
            const label = btn.querySelector('.sidebar-copy-label')
            if (!label) return
            try {
                await navigator.clipboard.writeText(window.location.href)
                const original = label.textContent
                label.textContent = 'Copied!'
                setTimeout(() => { label.textContent = original }, 1500)
            } catch (e) {}
        })
    })
</script>

<style>
    .post-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: var(--space-12);
        max-width: 1100px;
        margin: var(--space-10) auto var(--space-16);
        align-items: start;
    }

    .post-header {
        grid-column: 2 / 3;
    }

    .post-title {
        font-size: var(--font-size-display);
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        line-height: 1.2;
        margin: 0 0 var(--space-3);
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-ui);
        color: var(--color-text-muted);
    }

    .post-meta-sep {
        color: var(--color-border);
    }

    /* ── Sidebar ── */
    .post-sidebar {
        grid-column: 1 / 2;
        grid-row: 1 / span 2;
        position: sticky;
        top: var(--space-10);
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .back-link {
        font-size: var(--font-size-ui);
        font-weight: var(--font-weight-bold);
        color: var(--color-accent);
        text-decoration: none;
    }
    .back-link:hover { text-decoration: underline; }

    /* ── Sidebar sections ── */
    .sidebar-section {
        background: var(--color-bg-surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-card);
        padding: var(--space-4) var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .sidebar-section-label {
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-text-muted);
        margin: 0;
    }

    .sidebar-share-item {
        box-shadow: 0 0 0 1px #e0ddd6;
        border-radius: var(--radius-sm);
    }
    .sidebar-share-item:hover { box-shadow: 0 0 0 1px var(--color-accent); }

    .sidebar-share-link {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-sm);
        color: var(--color-text-dark);
        text-decoration: none;
        padding: var(--space-2) var(--space-3);
    }

    .sidebar-copy-btn {
        width: 100%;
        background: none;
        border: none;
        cursor: pointer;
        font-family: inherit;
        text-align: left;
    }
    .sidebar-share-item:hover .sidebar-share-link { color: var(--color-accent); }
    .sidebar-share-link svg { flex-shrink: 0; color: var(--color-accent); }

    .toc {
        display: flex;
        flex-direction: column;
    }

    .toc-link {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        text-decoration: none;
        line-height: 1.5;
        padding: var(--space-2) 0;
        border-bottom: 1px solid var(--color-border);
    }
    .toc-link:last-child { border-bottom: none; }
    .toc-link:hover { color: var(--color-accent); }
    .toc-h3 { padding-left: var(--space-3); }
    .toc-h4 { padding-left: var(--space-6); }

    /* ── Post content ── */
    .post-content :global(h2),
    .post-content :global(h3) {
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        margin: var(--space-10) 0 var(--space-3);
    }

    .post-content :global(h2) { font-size: var(--font-size-h2); }
    .post-content :global(h3) { font-size: var(--font-size-h3); margin-top: var(--space-8); }
    .post-content :global(h3:first-child) { margin-top: 0; }

    .post-content :global(p) {
        font-size: var(--font-size-body);
        color: var(--color-text-dark);
        line-height: 1.8;
        margin-bottom: var(--space-4);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
        margin: 0 0 var(--space-4) var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .post-content :global(li) {
        font-size: var(--font-size-body);
        color: var(--color-text-dark);
        line-height: 1.7;
    }

    .post-content :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
    }

    .post-content :global(img) {
        max-width: 100%;
        border-radius: var(--radius-md);
        margin: var(--space-6) auto;
        display: block;
    }

    .post-content :global(hr) {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: var(--space-8) 0;
    }

    .post-content :global(strong) {
        font-weight: var(--font-weight-bold);
    }

    /* ── Callout box (blockquote) ── */
    .post-content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        padding: var(--space-2) var(--space-3);
        margin: var(--space-4) 0;
    }

    .post-content :global(blockquote ol),
    .post-content :global(blockquote ul) {
        margin-left: 0;
        padding-left: var(--space-5);
    }

    .post-content :global(blockquote p),
    .post-content :global(blockquote li) {
        color: var(--color-text-dark);
        font-size: var(--font-size-body);
        margin: 0;
    }

    .post-content :global(blockquote ol),
    .post-content :global(blockquote ul) {
        margin-left: var(--space-5);
        gap: var(--space-3);
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .post-layout {
            grid-template-columns: 1fr;
            gap: var(--space-6);
        }

        .post-sidebar {
            position: static;
            flex-direction: row;
            align-items: center;
            flex-wrap: wrap;
            gap: var(--space-4);
            border-bottom: 1px solid var(--color-border);
            padding-bottom: var(--space-4);
        }

    }
</style>
