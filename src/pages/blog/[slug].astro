---
import Main from '../../layouts/Main.astro'
import Hero from '../../layouts/Hero.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
    const posts = await getCollection('blog')
    return posts.map(post => ({ params: { slug: post.id.replace(/\.md$/, '') }, props: { post } }))
}

const { post } = Astro.props
const { Content, headings } = await post.render()
---

<Main title={post.data.title}>

    <Hero title={post.data.title} variant="teal" slot="hero" />

    <div class="post-layout">

        <aside class="post-sidebar">
            <a class="back-link" href="/blog">← Back to Blogs</a>
            <div class="sidebar-meta">
                <p class="sidebar-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                <p class="sidebar-author">By {post.data.author}</p>
            </div>

            <div class="sidebar-section">
                <p class="sidebar-section-label">Share Article</p>
                <div class="sidebar-share-item">
                    <a class="sidebar-share-link" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.7 5.5 4.3 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                        Share on Twitter
                    </a>
                </div>
                <div class="sidebar-share-item">
                    <a class="sidebar-share-link" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                        Share on LinkedIn
                    </a>
                </div>
                <div class="sidebar-share-item">
                    <a class="sidebar-share-link" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                        Share on Facebook
                    </a>
                </div>
            </div>

            {headings.length > 0 && (
                <div class="sidebar-section">
                    <p class="sidebar-section-label">Table of Contents</p>
                    <nav class="toc">
                        {headings.map(h => (
                            <a class={`toc-link toc-h${h.depth}`} href={`#${h.slug}`}>{h.text}</a>
                        ))}
                    </nav>
                </div>
            )}
        </aside>

        <article class="post-body">
            <div class="post-content">
                <Content />
            </div>
        </article>

    </div>

</Main>

<style>
    .post-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: var(--space-12);
        max-width: 1100px;
        margin: var(--space-10) auto var(--space-16);
        align-items: start;
    }

    /* ── Sidebar ── */
    .post-sidebar {
        position: sticky;
        top: var(--space-10);
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .back-link {
        font-size: var(--font-size-ui);
        font-weight: var(--font-weight-bold);
        color: var(--color-accent);
        text-decoration: none;
    }
    .back-link:hover { text-decoration: underline; }

    .sidebar-meta {
        border-top: 1px solid var(--color-border);
        padding-top: var(--space-4);
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .sidebar-date {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        margin: 0;
    }

    .sidebar-author {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        margin: 0;
    }

    /* ── Sidebar sections ── */
    .sidebar-section {
        background: var(--color-bg-surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-card);
        padding: var(--space-4) var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .sidebar-section-label {
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-text-muted);
        margin: 0;
    }

    .sidebar-share-item {
        box-shadow: 0 0 0 1px #e0ddd6;
        border-radius: var(--radius-sm);
    }
    .sidebar-share-item:hover { box-shadow: 0 0 0 1px var(--color-accent); }

    .sidebar-share-link {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-sm);
        color: var(--color-text-dark);
        text-decoration: none;
        padding: var(--space-2) var(--space-3);
    }
    .sidebar-share-item:hover .sidebar-share-link { color: var(--color-accent); }
    .sidebar-share-link svg { flex-shrink: 0; color: var(--color-accent); }

    .toc {
        display: flex;
        flex-direction: column;
    }

    .toc-link {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        text-decoration: none;
        line-height: 1.5;
        padding: var(--space-2) 0;
        border-bottom: 1px solid var(--color-border);
    }
    .toc-link:last-child { border-bottom: none; }
    .toc-link:hover { color: var(--color-accent); }
    .toc-h3 { padding-left: var(--space-3); }
    .toc-h4 { padding-left: var(--space-6); }

    /* ── Post content ── */
    .post-content :global(h2),
    .post-content :global(h3) {
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        margin: var(--space-10) 0 var(--space-3);
    }

    .post-content :global(h2) { font-size: var(--font-size-h2); }
    .post-content :global(h3) { font-size: var(--font-size-h3); margin-top: var(--space-8); }
    .post-content :global(h3:first-child) { margin-top: 0; }

    .post-content :global(p) {
        font-size: var(--font-size-body);
        color: var(--color-text-dark);
        line-height: 1.8;
        margin-bottom: var(--space-4);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
        margin: 0 0 var(--space-4) var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .post-content :global(li) {
        font-size: var(--font-size-body);
        color: var(--color-text-dark);
        line-height: 1.7;
    }

    .post-content :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
    }

    .post-content :global(img) {
        max-width: 100%;
        border-radius: var(--radius-md);
        margin: var(--space-6) 0;
        display: block;
    }

    .post-content :global(hr) {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: var(--space-8) 0;
    }

    .post-content :global(strong) {
        font-weight: var(--font-weight-bold);
    }

    /* ── Callout box (blockquote) ── */
    .post-content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        padding: var(--space-2) var(--space-3);
        margin: var(--space-4) 0;
    }

    .post-content :global(blockquote ol),
    .post-content :global(blockquote ul) {
        margin-left: 0;
        padding-left: var(--space-5);
    }

    .post-content :global(blockquote p),
    .post-content :global(blockquote li) {
        color: var(--color-text-dark);
        font-size: var(--font-size-body);
        margin: 0;
    }

    .post-content :global(blockquote ol),
    .post-content :global(blockquote ul) {
        margin-left: var(--space-5);
        gap: var(--space-3);
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .post-layout {
            grid-template-columns: 1fr;
            gap: var(--space-6);
        }

        .post-sidebar {
            position: static;
            flex-direction: row;
            align-items: center;
            flex-wrap: wrap;
            gap: var(--space-4);
            border-bottom: 1px solid var(--color-border);
            padding-bottom: var(--space-4);
        }

        .sidebar-meta {
            border-top: none;
            padding-top: 0;
            border-left: 1px solid var(--color-border);
            padding-left: var(--space-4);
        }
    }
</style>
