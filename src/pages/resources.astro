---
import Main from '../layouts/Main.astro'
import Hero from '../layouts/Hero.astro'
import BookIcon from '../icons/book.svg?raw'
import CodeIcon from '../icons/code.svg?raw'
import ShareIcon from '../icons/share.svg?raw'

type ResourceItem = {
    title: string
    description: string
    href: string
    label: string
    icon: string
}

type ResourceGroup = {
    section: string
    intro: string
    items: ResourceItem[]
}

const resources: ResourceGroup[] = [
    {
        section: 'GitHub Basics',
        intro: 'New to GitHub? This step-by-step overview covers the core concepts and workflows you need to get started — no prior experience required.',
        items: [
            {
                title: 'The Basics of GitHub: Organizations, Repositories & Issues',
                description: 'Covers GitHub organizations, repositories, and issues — the key building blocks used across all ZAPP projects.',
                href: 'https://oboacademy.github.io/obook/howto/github-basics/',
                label: 'Read Guide',
                icon: BookIcon,
            },
        ],
    },
    {
        section: 'ZAPP Repositories',
        intro: 'Explore the ZAPP codebase, open issues, and contribute to ongoing development.',
        items: [
            {
                title: 'ZAPP Phenotype Atlas',
                description: 'The main repository for the Zebrafish Toxicology Phenotype Atlas — code, issues, and community collaboration.',
                href: 'https://github.com/zappfish/zapp-atlas',
                label: 'View Repository',
                icon: CodeIcon,
            },
            {
                title: 'ZAPP Toxicophenotype Data Model',
                description: 'Repository for the zebrafish toxicology atlas schema — data model, code, and issues.',
                href: 'https://github.com/zappfish/zebrafish-toxicology-atlas-schema',
                label: 'View Repository',
                icon: CodeIcon,
            },
            {
                title: 'ZAPP LinkML Schema Diagram',
                description: 'Interactive entity-relationship diagram of the zebrafish toxicophenotype schema, built with LinkML.',
                href: 'https://zappfish.org/zebrafish-toxicology-atlas-schema/schema_diagram/',
                label: 'View Diagram',
                icon: ShareIcon,
            },
        ],
    },
]
---

<Main title="Technical Resources">

    <Hero title="Technical Resources" variant="teal" slot="hero" />

    <section class="intro">
        <div class="section-label">Technical Resources</div>
        <p class="intro-text">Everything you need to get started, contribute, and explore the ZAPP ecosystem.</p>
    </section>

    {resources.map(group => (
        <section class="resource-group">
            <h2 class="group-heading">{group.section}</h2>
            {group.intro && <p class="group-intro">{group.intro}</p>}
            {group.items.length > 0 ? (
                <div class="resource-cards">
                    {group.items.map(item => (
                        <div class="resource-card">
                            <div class="resource-text">
                                <p class="resource-title">
                                    <span class="resource-icon" set:html={item.icon} aria-hidden="true" />
                                    {item.title}
                                </p>
                                <p class="resource-desc">{item.description}</p>
                            </div>
                            <a class="resource-link" href={item.href} target="_blank" rel="noopener noreferrer">
                                {item.label}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="13" height="13">
                                    <line x1="5" y1="12" x2="19" y2="12"/>
                                    <polyline points="12 5 19 12 12 19"/>
                                </svg>
                            </a>
                        </div>
                    ))}
                </div>
            ) : (
                <p class="coming-soon">Content coming soon — check back later.</p>
            )}
        </section>
    ))}

</Main>

<style>
    .intro {
        margin-bottom: var(--space-4);
    }

    .intro-text {
        font-size: var(--font-size-body);
        color: var(--color-text-body);
        line-height: 1.7;
        max-width: 640px;
    }

    .resource-group {
        margin-bottom: var(--space-8);
    }

    .group-heading {
        font-size: var(--font-size-h2);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-dark);
        margin-bottom: var(--space-2);
        padding-bottom: var(--space-3);
        border-bottom: 2px solid var(--color-accent);
        display: inline-block;
    }

    .group-intro {
        font-size: var(--font-size-body);
        color: var(--color-text-body);
        line-height: 1.7;
        margin-bottom: var(--space-4);
    }

    .resource-cards {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .resource-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        padding: var(--space-3) var(--space-5);
        background: var(--color-bg-white);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        box-shadow: var(--shadow-subtle);
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    }

    .resource-card:hover {
        border-color: var(--color-accent);
        box-shadow: var(--shadow-card);
        transform: translateY(-2px);
    }

    .resource-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .resource-title {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-body);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-dark);
        margin: 0;
    }

    .resource-icon {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: linear-gradient(135deg, rgba(42,157,138,0.15) 0%, rgba(26,83,92,0.10) 100%);
        border: 1px solid rgba(42,157,138,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-accent);
        position: relative;
        top: -1px;
    }

    .resource-icon :global(svg) {
        width: 16px;
        height: 16px;
    }

    .resource-desc {
        font-size: var(--font-size-ui);
        color: var(--color-text-muted);
        line-height: 1.6;
        margin: 0;
    }

    .resource-link {
        display: inline-flex;
        align-self: flex-start;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-3);
        background: var(--color-accent);
        color: var(--color-text-white);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        border-radius: 6px;
        text-decoration: none;
        transition: background 0.15s;
    }

    .resource-link:hover {
        background: var(--color-accent-hover);
    }

    .coming-soon {
        font-size: var(--font-size-body);
        color: var(--color-text-muted);
        font-style: italic;
    }
</style>
