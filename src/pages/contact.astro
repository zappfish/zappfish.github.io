---
import Main from '../layouts/Main.astro'
import Hero from '../layouts/Hero.astro'
import IconMail from '../components/icons/IconMail.astro'
import IconMessageSquare from '../components/icons/IconMessageSquare.astro'
import IconUsers from '../components/icons/IconUsers.astro'
import IconFileText from '../components/icons/IconFileText.astro'

const CONTACT_EMAIL  = 'info@zappfish.org'
const SLACK_URL      = 'https://docs.google.com/forms/d/e/1FAIpQLSdpQuXJSVGJgvYCFycwXSkIce_urbVIubZI_j69Rtuv6TSP4Q/viewform?pli=1'
const MAILING_URL    = 'https://docs.google.com/forms/d/e/1FAIpQLSfJcQehTjQZQHKil_aW0eTlRVewu154UOYGDEzGGoBb0la0Kg/viewform'
const HELPDESK_URL   = 'https://github.com/zappfish/helpdesk/issues'
---

<Main title="Contact Us">

    <Hero title="Contact Us" variant="teal" slot="hero" />

    <section class="intro">
        <div class="section-label">Get in Touch</div>
    </section>

    <section class="contact-layout" aria-label="Contact information">

        <div class="contact-info">
            <p class="contact-lead">
                Have questions about the project, want to collaborate, or need help getting involved? — We'd love to hear from you.
            </p>

            <h2 class="sub-heading">Ways to connect</h2>

            <div class="contact-channels">
                <div class="channel-card">
                    <div class="channel-icon"><IconMessageSquare /></div>
                    <div class="channel-body">
                        <span class="contact-label">Join the conversation</span>
                        <span class="channel-title">Chat with us on ZebrafishRocks!</span>
                    </div>
                    <a class="channel-cta" href={SLACK_URL} target="_blank" rel="noopener noreferrer">Join Slack</a>
                </div>

                <div class="channel-card">
                    <div class="channel-icon"><IconUsers /></div>
                    <div class="channel-body">
                        <span class="contact-label">Stay updated</span>
                        <span class="channel-title">Join our mailing list</span>
                    </div>
                    <a class="channel-cta" href={MAILING_URL} target="_blank" rel="noopener noreferrer">Sign up</a>
                </div>

                <div class="channel-card">
                    <div class="channel-icon"><IconMail /></div>
                    <div class="channel-body">
                        <span class="contact-label">Prefer email?</span>
                        <span class="channel-title">Drop us a line directly</span>
                    </div>
                    <a class="channel-cta" href={`mailto:${CONTACT_EMAIL}`}>Send email</a>
                </div>

                <div class="channel-card">
                    <div class="channel-icon"><IconFileText /></div>
                    <div class="channel-body">
                        <span class="contact-label">Have a specific question?</span>
                        <span class="channel-title">Submit a helpdesk ticket</span>
                    </div>
                    <a class="channel-cta" href={HELPDESK_URL} target="_blank" rel="noopener noreferrer">Open ticket</a>
                </div>
            </div>
        </div>

        <!-- Form hidden until API is ready
        <div>
            <h2 class="sub-heading">Prefer to send us a message?</h2>
            <form class="contact-form" method="POST" novalidate aria-label="Contact form">
                <div class="field">
                    <label for="name">Name <span aria-hidden="true">*</span></label>
                    <input id="name" name="name" type="text" placeholder="Your name" required aria-describedby="name-error" autocomplete="name" />
                    <span class="field-error" id="name-error" role="alert" aria-live="polite"></span>
                </div>

                <div class="field">
                    <label for="email">Email <span aria-hidden="true">*</span></label>
                    <input id="email" name="email" type="email" placeholder="your@email.com" required aria-describedby="email-error" autocomplete="email" />
                    <span class="field-error" id="email-error" role="alert" aria-live="polite"></span>
                </div>

                <div class="field">
                    <label for="subject">Subject <span aria-hidden="true">*</span></label>
                    <input id="subject" name="subject" type="text" placeholder="What is this about?" required aria-describedby="subject-error" autocomplete="off" />
                    <span class="field-error" id="subject-error" role="alert" aria-live="polite"></span>
                </div>

                <div class="field">
                    <label for="message">Message <span aria-hidden="true">*</span></label>
                    <textarea id="message" name="message" rows="5" placeholder="Your message..." required aria-describedby="message-error"></textarea>
                    <span class="field-error" id="message-error" role="alert" aria-live="polite"></span>
                </div>

                <div class="form-footer">
                    <button class="submit-btn" type="submit">Send Message</button>
                    <p class="form-notice" id="form-notice" role="alert" hidden>
                        This form is not yet active. Please reach out directly at
                        <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.
                    </p>
                </div>
            </form>
        </div>
        -->

    </section>

</Main>

<script>
    const form   = document.querySelector<HTMLFormElement>('.contact-form')!
    const notice = document.getElementById('form-notice')!

    const validators: Record<string, (v: string) => string> = {
        name:    v => v.trim() ? '' : 'Please enter your name.',
        email:   v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()) ? '' : 'Please enter a valid email address.',
        subject: v => v.trim() ? '' : 'Please enter a subject.',
        message: v => v.trim() ? '' : 'Please enter a message.',
    }

    function validateField(id: string): boolean {
        const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement
        const error = document.getElementById(`${id}-error`)
        if (!input || !error) return true
        const msg = validators[id]?.(input.value) ?? ''
        error.textContent = msg
        input.setAttribute('aria-invalid', msg ? 'true' : 'false')
        return !msg
    }

    Object.keys(validators).forEach(id =>
        document.getElementById(id)?.addEventListener('blur', () => validateField(id))
    )

    form.addEventListener('submit', e => {
        e.preventDefault()
        const valid = Object.keys(validators).map(validateField).every(Boolean)
        if (!valid) { form.querySelector<HTMLElement>('[aria-invalid="true"]')?.focus(); return }
        notice.hidden = false
        notice.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
    })
</script>

<style>
    .contact-layout {
        max-width: 520px;
        margin: 0 auto;
        padding-bottom: var(--space-16);
    }

    .contact-lead {
        font-size: var(--font-size-body);
        color: var(--color-text-body);
        line-height: 1.7;
        margin-bottom: var(--space-10);
    }

    .sub-heading {
        font-size: var(--font-size-body);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-dark);
        margin-bottom: var(--space-4);
    }

    /* ── Channels ── */
    .contact-channels { display: flex; flex-direction: column; gap: var(--space-4); }

    .channel-card {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        padding: var(--space-4) var(--space-5);
        background: var(--color-bg-white);
        border: 1.5px solid var(--color-border);
        border-radius: 12px;
        text-decoration: none;
        transition: box-shadow 0.15s, border-color 0.15s;
        outline-offset: 3px;
    }

    a.channel-card:hover       { border-color: var(--color-accent); box-shadow: 0 2px 12px rgba(42,157,138,0.12); }
    a.channel-card:focus-visible { outline: 2px solid var(--color-accent); }


    .channel-icon {
        flex-shrink: 0;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-accent-tint);
        color: var(--color-accent);
        border-radius: 10px;
    }

    .channel-icon :global(svg) { width: 20px; height: 20px; }

    .channel-body { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 0; }

    .contact-label {
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-text-muted);
    }

    .channel-title { font-size: var(--font-size-base); font-weight: var(--font-weight-bold); color: var(--color-text-dark); }

    .channel-cta {
        flex-shrink: 0;
        padding: var(--space-2) var(--space-4);
        background: var(--color-accent);
        color: var(--color-text-white);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        border-radius: 6px;
        white-space: nowrap;
        text-decoration: none;
    }

    .channel-cta:hover { background: var(--color-accent-hover); }
    .channel-cta:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 3px; }

    /* ── Form ── */
    .contact-form { display: flex; flex-direction: column; gap: var(--space-4); }

    .field { display: flex; flex-direction: column; gap: var(--space-1); }

    .field label { font-size: var(--font-size-sm); font-weight: var(--font-weight-bold); color: var(--color-text-dark); }
    .field label span { color: var(--color-accent); }

    .field input,
    .field textarea {
        font: inherit;
        color: var(--color-text-body);
        background: var(--color-bg-white);
        border: 1.5px solid var(--color-border);
        border-radius: 6px;
        padding: var(--space-3) var(--space-4);
        box-sizing: border-box;
        width: 100%;
        transition: border-color 0.15s;
    }

    .field input::placeholder,
    .field textarea::placeholder { color: var(--color-text-muted); }

    .field input:focus,
    .field textarea:focus { outline: none; border-color: var(--color-accent); }

    .field input[aria-invalid="true"],
    .field textarea[aria-invalid="true"] { border-color: var(--color-error, #c0392b); }

    .field textarea { resize: vertical; min-height: 120px; }

    .field-error { font-size: var(--font-size-sm); color: var(--color-error, #c0392b); }
    .field-error:empty { display: none; }

    .form-footer { display: flex; flex-direction: column; gap: var(--space-4); }

    .submit-btn {
        align-self: flex-start;
        padding: var(--space-3) var(--space-8);
        font: inherit;
        font-weight: var(--font-weight-bold);
        background: var(--color-accent);
        color: var(--color-text-white);
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.15s;
    }

    .submit-btn:hover { background: var(--color-accent-hover); }

    .form-notice {
        font-size: var(--font-size-base);
        color: var(--color-text-muted);
        background: var(--color-bg-light);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: var(--space-3) var(--space-4);
        margin: 0;
    }

    .form-notice a { color: var(--color-accent); }
</style>
