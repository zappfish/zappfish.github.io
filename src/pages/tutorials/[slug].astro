---
import Main from '../../layouts/Main.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
    const tutorials = await getCollection('tutorial')
    return tutorials.map(tutorial => ({ params: { slug: tutorial.id.replace(/\.md$/, '') }, props: { tutorial } }))
}

const { tutorial } = Astro.props
const { Content, headings } = await tutorial.render()

// "On this page" outline — all section headings (h2/h3) in document order.
const toc = headings.filter(h => h.depth === 2 || h.depth === 3)
---

<Main title={tutorial.data.title}>

    <Fragment slot="hero" />

    <div class="tut-layout">

        <aside class="tut-sidebar">
            <a class="back-link" href="/tutorials">← Back to Tutorials</a>

            {toc.length > 0 && (
                <nav class="toc" aria-label="On this page">
                    <p class="toc-label">On this page</p>
                    <ul class="toc-list">
                        {toc.map(h => (
                            <li>
                                <a class={`toc-link toc-h${h.depth}`} href={`#${h.slug}`} data-toc={h.slug}>{h.text}</a>
                            </li>
                        ))}
                    </ul>
                </nav>
            )}
        </aside>

        <article class="tut-body">
            <header class="tut-header">
                <span class="tut-badge">Tutorial</span>
                <h1 class="tut-title">{tutorial.data.title}</h1>
                {tutorial.data.excerpt && <p class="tut-excerpt">{tutorial.data.excerpt}</p>}
            </header>

            <div class="tut-content">
                <Content />
            </div>
        </article>

    </div>

</Main>

<script>
    // Highlight the current section in the "On this page" TOC as the reader scrolls.
    const links = Array.from(document.querySelectorAll('.toc-link')) as HTMLAnchorElement[]
    const map = new Map<string, HTMLAnchorElement>()
    links.forEach(l => {
        const id = l.getAttribute('data-toc')
        if (id) map.set(id, l)
    })

    const heads = Array.from(document.querySelectorAll('.tut-content h2, .tut-content h3'))
        .filter(h => h.id && map.has(h.id))

    if (heads.length && links.length) {
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    links.forEach(l => l.classList.remove('is-active'))
                    const link = map.get(entry.target.id)
                    if (link) link.classList.add('is-active')
                }
            })
        }, { rootMargin: '0px 0px -75% 0px', threshold: 0 })

        heads.forEach(h => observer.observe(h))
    }
</script>

<style>
    .tut-layout {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: var(--space-12);
        max-width: 1060px;
        margin: var(--space-8) auto var(--space-12);
        align-items: start;
    }

    /* ── Sidebar: "On this page" ── */
    .tut-sidebar {
        grid-column: 1 / 2;
        position: sticky;
        top: var(--space-10);
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .back-link {
        font-size: var(--font-size-ui);
        font-weight: var(--font-weight-bold);
        color: var(--color-accent);
        text-decoration: none;
    }
    .back-link:hover { text-decoration: underline; }

    .toc-label {
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-text-muted);
        margin: 0 0 var(--space-2);
    }

    .toc-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .toc-link {
        display: block;
        padding: var(--space-1) 0 var(--space-1) var(--space-3);
        border-left: 2px solid var(--color-border);
        text-decoration: none;
        color: var(--color-text-muted);
        font-size: var(--font-size-sm);
        line-height: 1.4;
        transition: color 0.15s, border-color 0.15s;
    }
    .toc-h3 { padding-left: var(--space-5); }

    .toc-link:hover { color: var(--color-text-dark); }
    .toc-link.is-active {
        color: var(--color-accent);
        border-left-color: var(--color-accent);
        font-weight: var(--font-weight-bold);
    }

    /* ── Body ── */
    .tut-body { grid-column: 2 / 3; min-width: 0; }

    .tut-header {
        padding-bottom: 0;
        margin-bottom: var(--space-4);
    }

    .tut-badge {
        display: inline-block;
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        background: color-mix(in srgb, var(--color-accent) 12%, transparent);
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-sm);
        margin-bottom: var(--space-4);
    }

    .tut-title {
        font-size: var(--font-size-display);
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        line-height: 1.2;
        margin: 0 0 var(--space-3);
    }

    .tut-excerpt {
        font-size: var(--font-size-body);
        color: var(--color-text-muted);
        line-height: 1.7;
        margin: 0 0 var(--space-4);
    }

    /* ── Content ── */
    .tut-content :global(h2),
    .tut-content :global(h3) {
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        scroll-margin-top: var(--space-8);
    }
    /* Section headings sit a clear step above body text (which is 1.125rem) */
    .tut-content :global(h2) { font-size: 1.6rem; margin: var(--space-8) 0 var(--space-3); }
    .tut-content :global(h3) { font-size: 1.35rem; margin: var(--space-8) 0 var(--space-3); }

    .tut-content :global(p) {
        font-size: var(--font-size-body);
        color: var(--color-text-dark);
        line-height: 1.65;
        margin-bottom: var(--space-3);
    }

    .tut-content :global(ul),
    .tut-content :global(ol) {
        margin: 0 0 var(--space-3) var(--space-5);
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }
    .tut-content :global(li) {
        font-size: var(--font-size-body);
        color: var(--color-text-dark);
        line-height: 1.7;
        padding-left: var(--space-1);
    }
    /* Nested lists indent by a consistent, smaller step so deep nesting stays readable */
    .tut-content :global(li ul),
    .tut-content :global(li ol) {
        margin-top: var(--space-2);
        margin-bottom: 0;
        margin-left: var(--space-4);
    }

    .tut-content :global(a) { color: var(--color-accent); text-decoration: underline; }

    /* Figures: centered, full content width, with consistent breathing room.
       Source images are exported at high resolution (~3000-5000px) and displayed
       here at column width, so they always downscale — staying sharp on retina. */
    .tut-content :global(img) {
        width: 100%;
        max-width: 100%;
        height: auto;
        border-radius: var(--radius-md);
        margin: var(--space-4) auto var(--space-2);
        display: block;
        box-shadow: var(--shadow-card);
    }

    /* Responsive 16:9 video embeds (YouTube iframe) */
    .tut-content :global(.video-embed) {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        margin: var(--space-4) auto var(--space-6);
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: var(--shadow-card);
    }
    .tut-content :global(.video-embed iframe) {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    /* figure captions (italic line right after an image) */
    .tut-content :global(p > em:only-child) {
        display: block;
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        text-align: center;
    }

    .tut-content :global(hr) {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: var(--space-6) 0;
    }

    /* Note callouts (blockquotes) */
    .tut-content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        background: color-mix(in srgb, var(--color-accent) 7%, transparent);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        padding: var(--space-3) var(--space-4);
        margin: var(--space-3) 0;
    }
    .tut-content :global(blockquote p) {
        margin: 0;
        font-size: var(--font-size-ui);
        color: var(--color-text-dark);
    }

    .tut-content :global(strong) { font-weight: var(--font-weight-bold); }
    .tut-content :global(sup), .tut-content :global(sub) {
        font-size: 0.75em; line-height: 0; position: relative; vertical-align: baseline;
    }
    .tut-content :global(sup) { top: -0.5em; }
    .tut-content :global(sub) { bottom: -0.25em; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .tut-layout { grid-template-columns: 1fr; gap: var(--space-6); }
        .tut-sidebar {
            grid-column: 1;
            position: static;
            border-bottom: 1px solid var(--color-border);
            padding-bottom: var(--space-4);
        }
        .tut-body { grid-column: 1; }
    }
</style>
