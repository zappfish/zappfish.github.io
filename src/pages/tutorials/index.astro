---
import Main from '../../layouts/Main.astro'
import Hero from '../../layouts/Hero.astro'
import { getCollection } from 'astro:content'

const tutorials = (await getCollection('tutorial')).sort(
    (a, b) => a.data.title.localeCompare(b.data.title)
)
---

<Main title="Tutorials">

    <Hero title="Tutorials" variant="teal" slot="hero" />

    <div class="section-label">Tutorials</div>
    <p class="intro-text">Hands-on, step-by-step guides for working with zebrafish data, ontologies, and standards. Learn how to find ontology terms, use community resources, and report your data consistently.</p>

    <section class="post-list">
        {tutorials.map(tutorial => (
            <a class="post-card" href={`/tutorials/${tutorial.id.replace(/\.md$/, '')}`}>
                <div class="post-card-text">
                    <h2 class="post-title">{tutorial.data.title}</h2>
                    {tutorial.data.excerpt && <p class="post-excerpt">{tutorial.data.excerpt}</p>}
                    <div class="post-footer">
                        <span class="post-read-more">Read more →</span>
                    </div>
                </div>
                {tutorial.data.image && (
                    <div class="post-card-image">
                        <img src={tutorial.data.image} alt={tutorial.data.title} />
                    </div>
                )}
            </a>
        ))}
    </section>

</Main>

<style>
    .intro-text {
        font-size: var(--font-size-body);
        color: var(--color-text-muted);
        line-height: 1.7;
        margin-bottom: var(--space-8);
    }

    .post-list {
        display: flex;
        flex-direction: column;
        margin-bottom: var(--space-12);
    }

    .post-card {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-8);
        padding: var(--space-6) 0;
        text-decoration: none;
        transition: opacity 0.15s;
    }

    .post-card + .post-card { border-top: 1px solid var(--color-border); }
    .post-card:hover { opacity: 0.75; }

    .post-card-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        min-width: 0;
    }

    .post-title {
        font-size: var(--font-size-h3);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-dark);
        margin: 0;
    }

    .post-excerpt {
        font-size: var(--font-size-body);
        color: var(--color-text-body);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .post-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: var(--space-1);
    }

    .post-read-more {
        font-size: var(--font-size-action);
        font-weight: var(--font-weight-bold);
        color: var(--color-accent);
    }

    .post-card-image {
        flex-shrink: 0;
        width: 240px;
        height: 160px;
        border-radius: 8px;
        overflow: hidden;
    }

    .post-card-image img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: var(--color-bg-light);
    }

    @media (max-width: 600px) {
        .post-card-image { display: none; }
    }
</style>
