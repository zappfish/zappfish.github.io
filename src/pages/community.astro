---
import Main from '../layouts/Main.astro'
import Hero from '../layouts/Hero.astro'
import SectionCard from '../components/ui/SectionCard.astro'
import IconUsers from '../components/icons/IconUsers.astro'
import IconUpload from '../components/icons/IconUpload.astro'
import IconEdit from '../components/icons/IconEdit.astro'
import IconCheckCircle from '../components/icons/IconCheckCircle.astro'
import IconLink from '../components/icons/IconLink.astro'
import IconStar from '../components/icons/IconStar.astro'

const communityRoles = [
    {
        title: 'Community Collaboration',
        description: 'Bring together a community of zebrafish toxicology scientists and toxicology and environmental health experts to discuss use cases, priorities, gather requirements, and organize testing.',
        icon: 'users',
    },
    {
        title: 'Research Submission',
        description: 'Engage researchers of the toxicology zebrafish community to create and submit images and phenotype annotations.',
        icon: 'upload',
    },
    {
        title: 'Community Curation',
        description: 'Include ontologists and data standards experts to ensure that standards conform to bioinformatics and FAIR principles',
        icon: 'edit',
    },
    {
        title: 'Community Testing and Sustainability',
        description: 'Foster a sustainable community by giving members the opportunities and tools to participate in this project: we will develop tutorials and organize training workshops, we will involve this community in the development of standard operating procedures (SOP) and curation guidelines.',
        icon: 'check',
    },
    {
        title: 'Involve Regulators & Community Integration',
        description: 'Create an environment in which every participant feels comfortable and empowered to actively participate. Incentives to participate will include travel funding and attribution of atlas and standards contributions, and usage metrics reported to contributors.',
        icon: 'link',
    },
]

const communityTypes = [
    'Zebrafish researchers',
    'Toxicologists',
    'Data standards and ontology experts',
    'Atlas experts',
    'Regulators',
]

const sabMembers = [
    { name: 'Jonathan Hamm (Chair)', affiliation: 'Inovit' },
    { name: 'Charles Lovely', affiliation: 'University of Louisville' },
    { name: 'Chris Mungall', affiliation: 'Lawrence Berkeley National Laboratory' },
    { name: 'Monte Westerfield', affiliation: 'University of Oregon' },
    { name: 'Philip Holmes', affiliation: 'National Institute of Environmental Health Sciences/National Institutes of Health' },
    { name: 'Robyn Tanguay', affiliation: 'Oregon State University' },
    { name: 'Stephanie Padilla', affiliation: 'U.S. Environmental Protection Agency' },
]
---

<Main title="Community">

    <Hero title="Community" image="/images/goals.jpeg" slot="hero">
        <p class="hero-subtitle">need something here</p>
    </Hero>

    <section class="intro">
        <div class="section-label">Community</div>
        <p>The Community plays an integral role in the success of this project.</p>
    </section>

    <section class="roles">
        <div class="roles-list">
            {communityRoles.map((role, i) => (
                <div class:list={['role-item', { 'role-item--last': i === communityRoles.length - 1 }]}>
                    <div class="role-icon">
                        {role.icon === 'users'  && <IconUsers />}
                        {role.icon === 'upload' && <IconUpload />}
                        {role.icon === 'edit'   && <IconEdit />}
                        {role.icon === 'check'  && <IconCheckCircle />}
                        {role.icon === 'link'   && <IconLink />}
                    </div>
                    <div class="role-content">
                        <h3>{role.title}</h3>
                        <p>{role.description}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <section class="who-is">
        <div class="who-card">
            <h2>Who is the Zebrafish Toxics Phenotype Atlas community and how can one join this community?</h2>
            <div class="community-types">
                {communityTypes.map(type => (
                    <span class="community-pill">{type}</span>
                ))}
            </div>
            <div class="join-cta">
                <p>Join the Zebrafish Toxicology Phenotype Atlas community by filling out <a href="#">this form</a>.</p>
            </div>
        </div>
    </section>

    <section class="sab">
        <SectionCard title="Scientific Advisory Board (SAB)" iconColor="teal">
            <IconStar slot="icon" />
            <div class="sab-body">
                <p class="sab-description">A Scientific Advisory Board (SAB) chaired by Jonathan Hamm meets annually to serve in an advisory capacity to ZAPP leadership about the status and direction of ZAPP. The board provides strategic observations and feedback on existing and proposed activities and partnerships, including prioritization of new development, external funding opportunities, operational issues, and long-term planning.</p>
                <div class="sab-grid">
                    {sabMembers.map(member => (
                        <div class="sab-member">
                            <strong>{member.name}</strong>
                            {member.affiliation && <span>{member.affiliation}</span>}
                        </div>
                    ))}
                </div>
            </div>
        </SectionCard>
    </section>

    <section class="upcoming">
        <div class="upcoming-item">
            <span class="upcoming-label">Upcoming</span>
            <span class="upcoming-sep">&rsaquo;</span>
            <a href="#">Governance</a>
        </div>
        <div class="upcoming-item">
            <span class="upcoming-label">Upcoming</span>
            <span class="upcoming-sep">&rsaquo;</span>
            <a href="#">Submit date</a>
        </div>
    </section>

</Main>

<style>
    .hero-subtitle { color: var(--color-text-white); margin: 0; opacity: 0.92; }

    /* ── Section label ── */
    .section-label {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text-muted);
        margin-bottom: var(--space-3);
    }
    .section-label::before {
        content: '';
        display: block;
        width: 28px;
        height: 2px;
        background: var(--color-accent);
        flex-shrink: 0;
    }

    /* ── Community roles ── */
    .role-item {
        display: flex;
        gap: var(--space-4);
        align-items: flex-start;
        padding: var(--space-4) 0;
        border-bottom: 1px solid var(--color-border);
    }
    .role-item--last { border-bottom: none; }

    .role-icon {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 2px solid var(--color-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-accent);
        margin-top: 2px;
    }
    .role-icon :global(svg) { width: 16px; height: 16px; }

    .role-content h3 {
        font-size: var(--font-size-h3);
        margin-bottom: var(--space-2);
        color: var(--color-primary);
    }
    .role-content p { margin-bottom: 0; font-size: var(--font-size-body); color: var(--color-text-dark); }

    /* ── Who is the community ── */
    .who-card {
        background: var(--color-bg-surface);
        border-radius: 10px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.10);
        overflow: hidden;
    }

    .who-card h2 {
        padding: var(--space-4) var(--space-6) var(--space-3);
        margin-bottom: 0;
        font-size: var(--font-size-h2);
        color: var(--color-primary);
        text-align: center;
    }

    .community-types {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        justify-content: center;
        padding: 0 var(--space-6) var(--space-4);
    }

    .community-pill {
        display: inline-block;
        padding: var(--space-2) var(--space-6);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        font-size: var(--font-size-base);
        color: var(--color-text-dark);
        background: var(--color-bg-white);
        cursor: default;
    }

    .join-cta {
        background: var(--color-primary);
        padding: var(--space-3) var(--space-6);
        text-align: center;
    }
    .join-cta p {
        margin-bottom: 0;
        color: var(--color-text-white);
        font-size: var(--font-size-base);
    }
    .join-cta a {
        color: var(--color-accent);
        font-weight: var(--font-weight-bold);
        text-decoration: underline;
    }
    .join-cta a:hover { color: #fff; }

    /* ── SAB ── */
    .sab-body { padding: var(--space-4) var(--space-6); }

    .sab-description {
        margin-bottom: var(--space-4);
        color: var(--color-text-dark);
    }

    .sab-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
        margin-bottom: var(--space-4);
    }

    .sab-member {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        padding: var(--space-4);
        background: var(--color-bg-base);
        border-radius: 6px;
    }
    .sab-member strong { font-size: var(--font-size-base); color: var(--color-primary); }
    .sab-member span { font-size: var(--font-size-sm); color: var(--color-text-muted); }

    .sab-actions {
        display: flex;
        gap: var(--space-4);
        justify-content: center;
        flex-wrap: wrap;
    }

    .sab-btn {
        display: inline-block;
        padding: var(--space-3) var(--space-8);
        background: var(--color-primary);
        color: var(--color-text-white);
        text-decoration: none;
        border-radius: 4px;
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-bold);
        transition: background 0.15s;
    }
    .sab-btn:hover { background: var(--color-primary-dark); color: var(--color-text-white); }

    /* ── Upcoming ── */
    .upcoming {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        border-top: 2px solid var(--color-border);
        padding-top: var(--space-6);
    }

    .upcoming-item {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        font-size: var(--font-size-h3);
        background: var(--color-bg-surface);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: var(--space-4) var(--space-6);
    }

    .upcoming-label {
        font-weight: var(--font-weight-bold);
        color: var(--color-text-white);
        text-transform: uppercase;
        font-size: var(--font-size-sm);
        letter-spacing: 0.05em;
        background: var(--color-accent);
        padding: var(--space-1) var(--space-3);
        border-radius: 4px;
    }

    .upcoming-sep {
        color: var(--color-accent);
        font-size: 1.4rem;
    }

    .upcoming-item a {
        color: var(--color-primary);
        text-decoration: none;
        font-weight: var(--font-weight-bold);
        font-size: var(--font-size-h3);
    }
    .upcoming-item a:hover { color: var(--color-accent); text-decoration: underline; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .role-item { gap: var(--space-4); padding: var(--space-4) var(--space-6); }
        .sab-grid { grid-template-columns: 1fr; }
        .sab-actions { flex-direction: column; align-items: center; }
        .sab-btn { width: 100%; text-align: center; }
    }
</style>
