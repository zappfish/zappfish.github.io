---
import Main from '../layouts/Main.astro'
import Hero from '../layouts/Hero.astro'
import CommunityRoles from '../components/community/CommunityRoles.astro'
import CommunityWho from '../components/community/CommunityWho.astro'
import ActionCard from '../components/ui/ActionCard.astro'
import IconShield from '../components/icons/IconShield.astro'
import IconDatabase from '../components/icons/IconDatabase.astro'
---

<Main title="Community">

    <Hero title="Community" variant="teal" slot="hero" />

    <section class="intro">
        <div class="section-label">Community</div>
        <p>The Community plays an integral role in the success of this project.</p>
    </section>

    <section class="who-is">
        <CommunityWho />
    </section>

    <section class="roles">
        <h2 class="roles-heading">Built by the Community</h2>
        <CommunityRoles />
    </section>

    <section class="join-cta">
        <p>Ready to join the Zebrafish Toxicology Phenotype Atlas community?</p>
        <a href="/get-involved" class="join-btn">Join Now</a>
    </section>

    <section class="action-cards">
        <ActionCard title="Governance" description="Documents, policies, and contribution guidelines" href="/ZAPPGovernance" linkLabel="View Governance">
            <IconShield slot="icon" />
        </ActionCard>
        <ActionCard title="Submit Data" description="Coming Soon" href="#" comingSoon>
            <IconDatabase slot="icon" />
        </ActionCard>
    </section>

</Main>

<style>
    .action-cards { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); }

    .roles-heading { text-align: center; margin-top: var(--space-12); margin-bottom: var(--space-4); }


    .join-cta {
        background: var(--color-primary);
        padding: var(--space-6) var(--space-8);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-6);
    }
    .join-cta p { margin-bottom: 0; color: var(--color-text-white); }
    .join-btn {
        display: inline-block;
        white-space: nowrap;
        padding: var(--space-3) var(--space-8);
        background: var(--color-accent);
        color: var(--color-text-white);
        text-decoration: none;
        border-radius: 4px;
        font-size: var(--font-size-ui);
        font-weight: var(--font-weight-bold);
        transition: background 0.15s;
        flex-shrink: 0;
    }
    .join-btn:hover { background: var(--color-accent-hover); }

    @media (max-width: 768px) {
        .action-cards { grid-template-columns: 1fr; }
        .join-cta { flex-direction: column; text-align: center; }
    }
</style>
