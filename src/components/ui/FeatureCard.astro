---
const { title, cardTitle, description, href, btnLabel } = Astro.props
---

<div class="card">
<h3 set:html={cardTitle ?? title} />
    <p>{description}</p>
    <a href={href} class="card-btn">{btnLabel}</a>
</div>

<style>
    .card {
        padding: var(--space-8);
        background: var(--color-primary-dark);
        border-radius: var(--radius-md);
        display: flex;
        flex-direction: column;
    }

    .card h3 { font-size: var(--font-size-h3); margin-bottom: var(--space-3); color: var(--color-text-white); }

    .card p { margin-bottom: var(--space-6); color: var(--color-white-65); }

    .card-btn {
        display: inline-block;
        padding: var(--space-2) var(--space-6);
        background: var(--color-bg-base);
        color: var(--color-primary-dark);
        text-decoration: none;
        border-radius: var(--radius-sm);
        font-weight: var(--font-weight-bold);
        font-size: var(--font-size-ui);
        align-self: flex-start;
        transition: background var(--transition-fast), color var(--transition-fast);
    }

    .card-btn:hover {
        background: var(--color-bg-light);
    }
</style>
