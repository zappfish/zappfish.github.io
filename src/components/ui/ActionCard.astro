---
interface Props {
    title: string
    description: string
    href: string
    linkLabel?: string
}
const { title, description, href, linkLabel } = Astro.props
---
<div class="action-card">
    <div class="action-card-icon">
        <slot name="icon" />
    </div>
    <div class="action-card-body">
        <h3>{title}</h3>
        <p>{description}</p>
        {linkLabel && <a href={href} class="action-link">{linkLabel} &rsaquo;</a>}
    </div>
</div>

<style>
    .action-card {
        background: var(--color-bg-surface);
        border-radius: 10px;
        padding: var(--space-8);
        box-shadow: 0 4px 20px rgba(0,0,0,0.10);
        display: flex;
        gap: var(--space-4);
        align-items: flex-start;
    }
    .action-card-icon {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--color-bg-base);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-primary);
    }
    .action-card-icon :global(svg) { width: 18px; height: 18px; }
    .action-card h3 { font-size: var(--font-size-h3); margin-bottom: var(--space-2); }
    .action-card-body { flex: 1; display: flex; flex-direction: column; }
    .action-card p {
        display: inline-block;
        align-self: center;
        color: var(--color-text-muted);
        background: transparent;
        border: 1px dashed rgba(0,0,0,0.25);
        border-radius: 20px;
        padding: 2px 12px;
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        line-height: var(--line-height-base);
        margin-bottom: var(--space-2);
    }
    .action-link { font-weight: var(--font-weight-bold); color: var(--color-accent); text-decoration: none; }
    .action-link:hover { text-decoration: underline; }
</style>
