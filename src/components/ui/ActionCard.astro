---
interface Props {
    title: string
    description: string
    href: string
    linkLabel?: string
    comingSoon?: boolean
}
const { title, description, href, linkLabel, comingSoon } = Astro.props
---
<div class="action-card">
    <div class="action-card-icon">
        <slot name="icon" />
    </div>
    <div class="action-card-body">
        <h3>{title}</h3>
        <p class={comingSoon ? 'coming-soon' : ''}>{description}</p>
        {linkLabel && <a href={href} class="action-link">{linkLabel} &rsaquo;</a>}
    </div>
</div>

<style>
    .action-card {
        background: var(--color-bg-surface);
        border-radius: var(--radius-lg);
        padding: var(--space-8);
        box-shadow: var(--shadow-card);
        display: flex;
        gap: var(--space-4);
        align-items: flex-start;
    }
    .action-card-icon {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--color-bg-base);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-primary);
    }
    .action-card-icon :global(svg) { width: 18px; height: 18px; }
    .action-card h3 { font-size: var(--font-size-h3); margin-bottom: var(--space-2); }
    .action-card-body { flex: 1; display: flex; flex-direction: column; }
    .action-card p {
        color: var(--color-text-dark);
        font-size: var(--font-size-body);
        line-height: var(--line-height-base);
        margin-bottom: var(--space-2);
    }
    .action-card p.coming-soon {
        display: inline-block;
        align-self: center;
        border: 1px dashed rgba(0,0,0,0.3);
        border-radius: 20px;
        padding: 2px var(--space-4);
        font-size: var(--font-size-ui);
        color: var(--color-text-muted);
        text-align: center;
    }
    .action-link { font-weight: var(--font-weight-bold); color: var(--color-accent); text-decoration: none; }
    .action-link:hover { text-decoration: underline; }
</style>
