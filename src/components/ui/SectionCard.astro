---
interface Props {
    title?: string
    subtitle?: string
    iconColor?: 'green' | 'teal' | 'dark'
}
const { title, subtitle, iconColor = 'teal' } = Astro.props
const hasIcon = Astro.slots.has('icon')
const hasHeader = !!title || hasIcon
---
<div class="section-card">
    {hasHeader && (
        <div class="section-card-header">
            {hasIcon && (
                <div class={`section-icon section-icon--${iconColor}`}>
                    <slot name="icon" />
                </div>
            )}
            {title && (
                <div>
                    <h2>{title}</h2>
                    {subtitle && <p class="section-subtitle">{subtitle}</p>}
                </div>
            )}
        </div>
    )}
    <div class="section-card-body">
        <slot />
    </div>
</div>

<style>
    .section-card {
        background: var(--color-bg-surface);
        border-radius: 10px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.10);
        overflow: hidden;
    }

    .section-card-header {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        padding: var(--space-3) var(--space-6);
        background: linear-gradient(135deg, rgba(42, 157, 138, 0.12) 0%, rgba(26, 83, 92, 0.08) 100%);
        border-bottom: 1px solid var(--color-border);
    }

    .section-card-header h2 { margin-bottom: 0; }
    .section-subtitle { font-size: var(--font-size-base); color: var(--color-text-muted); margin: var(--space-1) 0 0; }

    .section-icon {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
    }
    .section-icon :global(svg) { width: 14px; height: 14px; color: #fff; }
    .section-icon--green { background: var(--color-accent); }
    .section-icon--teal  { background: var(--color-primary-dark); }
    .section-icon--dark  { background: var(--color-primary); }
</style>
