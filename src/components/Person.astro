---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"

interface Props {
    person: CollectionEntry<"pis"> | CollectionEntry<"team">
}
const { person } = Astro.props
---

<div class="person-card">
    <div class="person-photo">
        {person.data.image
            ? <Image src={person.data.image} alt={person.data.name} width={460} height={440} />
            : <div class="photo-placeholder" aria-hidden="true" />
        }
    </div>
    <div class="person-info">
        <strong class="person-name">{person.data.name}</strong>
        {person.data.project_role     && <span class="person-role">{person.data.project_role}</span>}
        {person.data.institution_role && <span class="person-institution-role">{person.data.institution_role}</span>}
        {person.data.institution      && <span class="person-institution">{person.data.institution}</span>}
    </div>
</div>

<style>
    .person-card {
        display: flex;
        flex-direction: column;
        background: var(--color-bg-white);
        border-radius: 10px;
        border: 1px solid var(--color-border);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
        overflow: hidden;
    }

    .person-photo {
        width: 100%;
        aspect-ratio: 1 / 1;
        overflow: hidden;
    }

    .person-photo img,
    .photo-placeholder {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 25%;
    }

    .photo-placeholder {
        background: var(--color-bg-surface);
        border-bottom: 1px dashed var(--color-border);
    }

    .person-info {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        padding: var(--space-4) var(--space-4) var(--space-6);
    }

    .person-name {
        color: var(--color-accent);
        font-size: var(--font-size-h3);
        font-weight: var(--font-weight-bold);
        line-height: var(--line-height-tight);
    }

    .person-role {
        color: var(--color-text-dark);
        font-size: var(--font-size-h4);
        font-weight: var(--font-weight-bold);
    }

    .person-institution-role {
        color: var(--color-text-dark);
        font-size: var(--font-size-body);
    }

    .person-institution {
        color: var(--color-text-muted);
        font-size: var(--font-size-base);
    }
</style>
