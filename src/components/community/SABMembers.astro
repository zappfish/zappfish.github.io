---
import SectionCard from '../ui/SectionCard.astro'
import IconStar from '../icons/IconStar.astro'

const members = [
    { name: 'Jonathan Hamm (Chair)', affiliation: 'Inovit' },
    { name: 'Charles Lovely',        affiliation: 'University of Louisville' },
    { name: 'Chris Mungall',         affiliation: 'Lawrence Berkeley National Laboratory' },
    { name: 'Monte Westerfield',     affiliation: 'University of Oregon' },
    { name: 'Philip Holmes',         affiliation: 'National Institute of Environmental Health Sciences/National Institutes of Health' },
    { name: 'Robyn Tanguay',         affiliation: 'Oregon State University' },
    { name: 'Stephanie Padilla',     affiliation: 'U.S. Environmental Protection Agency' },
]
---

<SectionCard title="Scientific Advisory Board (SAB)" iconColor="teal">
    <IconStar slot="icon" aria-hidden="true" />
    <div class="sab-body">
        <p class="sab-description">A Scientific Advisory Board (SAB) chaired by Jonathan Hamm meets annually to serve in an advisory capacity to ZAPP leadership about the status and direction of ZAPP. The board provides strategic observations and feedback on existing and proposed activities and partnerships, including prioritization of new development, external funding opportunities, operational issues, and long-term planning.</p>
        <div class="sab-grid">
            {members.map(member => (
                <div class="sab-member">
                    <strong>{member.name}</strong>
                    {member.affiliation && <span>{member.affiliation}</span>}
                </div>
            ))}
        </div>
    </div>
</SectionCard>

<style>
    .sab-body { padding: var(--space-4) var(--space-6); }

    .sab-description {
        margin-bottom: var(--space-4);
        color: var(--color-text-dark);
    }

    .sab-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
    }

    .sab-member {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        padding: var(--space-4);
        background: var(--color-bg-base);
        border-radius: 6px;
    }
    .sab-member strong { color: var(--color-primary); }
    .sab-member span   { font-size: var(--font-size-base); color: var(--color-text-muted); }

    @media (max-width: 768px) {
        .sab-grid { grid-template-columns: 1fr; }
    }
</style>
