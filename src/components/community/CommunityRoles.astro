---
import IconUsers from '../icons/IconUsers.astro'
import IconUpload from '../icons/IconUpload.astro'
import IconEdit from '../icons/IconEdit.astro'
import IconCheckCircle from '../icons/IconCheckCircle.astro'
import IconLink from '../icons/IconLink.astro'

const icons: Record<string, any> = {
    users:  IconUsers,
    upload: IconUpload,
    edit:   IconEdit,
    check:  IconCheckCircle,
    link:   IconLink,
}

const roles = [
    { title: 'Community Collaboration',              icon: 'users',  description: 'Bring together a community of zebrafish toxicology scientists and toxicology and environmental health experts to discuss use cases, priorities, gather requirements, and organize testing.' },
    { title: 'Research Submission',                  icon: 'upload', description: 'Engage researchers of the toxicology zebrafish community to create and submit images and phenotype annotations.' },
    { title: 'Community Curation',                   icon: 'edit',   description: 'Include ontologists and data standards experts to ensure that standards conform to bioinformatics and FAIR principles' },
    { title: 'Community Testing and Sustainability',  icon: 'check',  description: 'Foster a sustainable community by giving members the opportunities and tools to participate in this project: we will develop tutorials and organize training workshops, we will involve this community in the development of standard operating procedures (SOP) and curation guidelines.' },
    { title: 'Involve Regulators & Community Integration', icon: 'link', description: 'Create an environment in which every participant feels comfortable and empowered to actively participate. Incentives to participate will include travel funding and attribution of atlas and standards contributions, and usage metrics reported to contributors.' },
]
---

<div class="roles-list">
    {roles.map((role, i) => {
        const Icon = icons[role.icon]
        return (
            <div class:list={['role-item', { 'role-item--last': i === roles.length - 1 }]}>
                <div class="role-icon"><Icon /></div>
                <div class="role-content">
                    <h3>{role.title}</h3>
                    <p>{role.description}</p>
                </div>
            </div>
        )
    })}
</div>

<style>
    .role-item {
        display: flex;
        gap: var(--space-4);
        align-items: flex-start;
        padding: var(--space-4) 0;
        border-bottom: 1px solid var(--color-border);
    }
    .role-item--last { border-bottom: none; }

    .role-icon {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 2px solid var(--color-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-accent);
        margin-top: 2px;
    }
    .role-icon :global(svg) { width: 16px; height: 16px; }

    .role-content h3 {
        font-size: var(--font-size-h3);
        margin-bottom: var(--space-2);
        color: var(--color-primary);
    }
    .role-content p { margin-bottom: 0; font-size: var(--font-size-body); color: var(--color-text-dark); }

    @media (max-width: 768px) {
        .role-item { gap: var(--space-4); padding: var(--space-4) var(--space-6); }
    }
</style>
